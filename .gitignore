#include <iostream>
#include <string>
#include <climits>
using namespace std;

// 坐标点结构体
struct Point {
    int x;
    int y;
};

// 地点信息结构体：名称 + 坐标 + 编号
struct Place {
    string name;
    Point p;
    int id; // 内部编号，方便邻接表索引
};

// 边结构体：目标地点id、距离、预计时间
struct Edge {
    int toId;
    int distance; // 距离（米）
    int time;     // 预计时间（秒）
};

// 邻接表：每个地点的边列表（用固定大小数组模拟）
struct AdjList {
    Edge edges[20]; // 每个地点最多20条边
    int edgeCount;
};

// 栈结构体：用于路径回溯（数组模拟栈）
struct Stack {
    int data[50];
    int top;
    Stack() : top(-1) {}
    bool isEmpty() { return top == -1; }
    void push(int val) { if (top < 49) data[++top] = val; }
    int pop() { return data[top--]; }
};

// 校园导航系统类（无STL版本）
class CampusQuerySystem {
private:
    static const int MAX_PLACES = 50;
    Place campusPlaces[MAX_PLACES];
    AdjList adj[MAX_PLACES]; // 邻接表
    int placeCount;

    // 根据名称找地点id
    int getPlaceIdByName(const string& name) {
        for (int i = 0; i < placeCount; i++) {
            if (campusPlaces[i].name == name)
                return i;
        }
        return -1;
    }

